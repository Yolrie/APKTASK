<?xml version="1.0" encoding="utf-8"?>
<!--
  MD3 card item for COMPLETED (green) and CANCELLED (red) tasks.
  Read-only — no action buttons. ID tvTaskTitle must stay stable (TaskAdapter binds it).
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/card_margin_vertical"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutline">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/space_sm"
        android:gravity="center_vertical"
        android:minHeight="@dimen/task_item_min_height">

        <!-- Colored status indicator -->
        <View
            android:id="@+id/viewStatusBar"
            android:layout_width="@dimen/task_status_bar_width"
            android:layout_height="match_parent"
            android:layout_marginEnd="@dimen/space_sm"
            android:minHeight="@dimen/task_item_min_height" />

        <TextView
            android:id="@+id/tvTaskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:paddingHorizontal="@dimen/space_xs" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
