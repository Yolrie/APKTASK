<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ═══════════════════════════════════════════
         DARK MODE MONOCHROME PALETTE
         Single accent: Electric Cyan #00D4FF
    ═══════════════════════════════════════════ -->

    <!-- Core surfaces -->
    <color name="primary">#00D4FF</color>           <!-- Electric cyan accent -->
    <color name="primary_light">#33DDFF</color>      <!-- Lighter cyan for hover/pressed -->
    <color name="primary_dark">#00A8CC</color>        <!-- Darker cyan variant -->
    <color name="accent">#00D4FF</color>              <!-- Single vivid accent -->

    <!-- Backgrounds & Surfaces -->
    <color name="background">#0D0D0D</color>          <!-- Near-black background -->
    <color name="surface">#1A1A1A</color>             <!-- Card/surface color -->
    <color name="surface_elevated">#252525</color>    <!-- Elevated surface -->
    <color name="surface_variant">#1E1E1E</color>     <!-- Alternative surface -->

    <!-- Text -->
    <color name="text_primary">#F5F5F5</color>        <!-- Near-white primary text -->
    <color name="text_secondary">#9E9E9E</color>      <!-- Medium grey secondary -->
    <color name="text_tertiary">#666666</color>        <!-- Faint tertiary text -->
    <color name="text_on_accent">#000000</color>       <!-- Black text on accent buttons -->

    <!-- Borders & Dividers -->
    <color name="border">#2A2A2A</color>              <!-- Subtle dark borders -->
    <color name="border_light">#333333</color>         <!-- Slightly visible border -->

    <!-- Semantic colors (muted for dark mode) -->
    <color name="success">#4ADE80</color>             <!-- Muted green -->
    <color name="error">#F87171</color>               <!-- Muted red -->
    <color name="warning">#FBBF24</color>             <!-- Muted amber -->

    <!-- Avatar colors (vivid, good on dark bg) -->
    <color name="avatar_0">#00D4FF</color>            <!-- Cyan (accent) -->
    <color name="avatar_1">#4ADE80</color>            <!-- Green -->
    <color name="avatar_2">#FBBF24</color>            <!-- Amber -->
    <color name="avatar_3">#F87171</color>            <!-- Red -->
    <color name="avatar_4">#A78BFA</color>            <!-- Violet -->
    <color name="avatar_5">#F472B6</color>            <!-- Pink -->
    <color name="avatar_6">#2DD4BF</color>            <!-- Teal -->
    <color name="avatar_7">#FB923C</color>            <!-- Orange -->

    <!-- Bottom navigation -->
    <color name="nav_background">#0D0D0D</color>      <!-- Dark nav bar -->
    <color name="nav_indicator">#1A3A40</color>        <!-- Subtle cyan tint for indicator -->

    <!-- Progress bar -->
    <color name="progress_track">#2A2A2A</color>      <!-- Dark track -->
    <color name="progress_indicator">#00D4FF</color>   <!-- Cyan fill -->

