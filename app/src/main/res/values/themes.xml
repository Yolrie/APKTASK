<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ═══════════════════════════════════════════
         APKTASK — DARK MODE ONLY (Material 3)
         Elegant monochrome with cyan accent
    ═══════════════════════════════════════════ -->

    <style name="Base.Theme.APKTASK" parent="Theme.Material3.Dark.NoActionBar">

        <!-- Primary (accent cyan) -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryContainer">#003844</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorOnPrimaryContainer">#B3EFFF</item>

        <!-- Secondary (neutral grey) -->
        <item name="colorSecondary">#9E9E9E</item>
        <item name="colorSecondaryContainer">#2A2A2A</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="colorOnSecondaryContainer">#E0E0E0</item>

        <!-- Tertiary -->
        <item name="colorTertiary">#4ADE80</item>
        <item name="colorTertiaryContainer">#1A3D2A</item>
        <item name="colorOnTertiary">#000000</item>
        <item name="colorOnTertiaryContainer">#B3F5CC</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
        <item name="colorErrorContainer">#3D1A1A</item>
        <item name="colorOnError">#000000</item>
        <item name="colorOnErrorContainer">#FFB3B3</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorSurfaceContainerLowest">#080808</item>
        <item name="colorSurfaceContainerLow">#121212</item>
        <item name="colorSurfaceContainer">@color/surface</item>
        <item name="colorSurfaceContainerHigh">@color/surface_elevated</item>
        <item name="colorSurfaceContainerHighest">#2E2E2E</item>

        <!-- Outline -->
        <item name="colorOutline">@color/border_light</item>
        <item name="colorOutlineVariant">@color/border</item>

        <!-- System bars — dark/transparent -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>

        <!-- Widget overrides -->
        <item name="materialCardViewStyle">@style/DarkCardStyle</item>
        <item name="materialButtonStyle">@style/DarkPrimaryButton</item>
        <item name="materialButtonOutlinedStyle">@style/DarkOutlinedButton</item>
        <item name="textInputStyle">@style/DarkTextInputLayout</item>
        <item name="sliderStyle">@style/DarkSliderStyle</item>
        <item name="linearProgressIndicatorStyle">@style/DarkProgressIndicator</item>
        <item name="switchStyle">@style/DarkSwitchStyle</item>
        <item name="bottomNavigationStyle">@style/DarkBottomNav</item>

        <!-- Snackbar -->
        <item name="snackbarStyle">@style/DarkSnackbar</item>
        <item name="snackbarTextViewStyle">@style/DarkSnackbarText</item>
    </style>

    <style name="Theme.APKTASK" parent="Base.Theme.APKTASK" />

    <!-- ═══════════════════════════════════════════
         WIDGET STYLES
    ═══════════════════════════════════════════ -->

    <!-- MaterialCardView: dark surface, rounded corners, subtle border -->
    <style name="DarkCardStyle" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Primary button: filled accent -->
    <style name="DarkPrimaryButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Outlined button: subtle border, light text -->
    <style name="DarkOutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/outline_button_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/outline_button_text</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">#1A00D4FF</item>
    </style>

    <!-- Text input: outlined with subtle border -->
    <style name="DarkTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxBackgroundColor">@color/surface_variant</item>
        <item name="hintTextColor">@color/accent</item>
        <item name="android:textColorHint">@color/text_tertiary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- Slider: accent track -->
    <style name="DarkSliderStyle" parent="Widget.Material3.Slider">
        <item name="thumbColor">@color/accent</item>
        <item name="trackColorActive">@color/accent</item>
        <item name="trackColorInactive">@color/border_light</item>
        <item name="haloColor">#3300D4FF</item>
    </style>

    <!-- Progress indicator: cyan on dark track -->
    <style name="DarkProgressIndicator" parent="Widget.Material3.LinearProgressIndicator">
        <item name="indicatorColor">@color/accent</item>
        <item name="trackColor">@color/progress_track</item>
        <item name="trackThickness">6dp</item>
        <item name="trackCornerRadius">3dp</item>
    </style>

    <!-- Switch: accent when on -->
    <style name="DarkSwitchStyle" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">@color/accent</item>
        <item name="trackTint">@color/border_light</item>
    </style>

    <!-- Bottom Navigation: dark bg, cyan selected -->
    <style name="DarkBottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/nav_background</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/DarkNavIndicator</item>
    </style>

    <style name="DarkNavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/nav_indicator</item>
    </style>

    <!-- Snackbar -->
    <style name="DarkSnackbar" parent="Widget.Material3.Snackbar">
        <item name="backgroundTint">@color/surface_elevated</item>
    </style>

    <style name="DarkSnackbarText" parent="Widget.Material3.Snackbar.TextView">
        <item name="android:textColor">@color/text_primary</item>
    </style>

</resources>
